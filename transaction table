CREATE TABLE transactions(
id INT AUTO_INCREMENT PRIMARY KEY,
user_id INT NOT NULL,
 date DATE NOT NULL,
 product VARCHAR(100) NOT NULL,
qty INT NOT NULL,
paid INT NOT NULL,
due INT NOT NULL,
FOREIGN KEY(user_id) REFERENCES users(id)
);

