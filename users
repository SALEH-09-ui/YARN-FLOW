USE YarnFlow_db;

CREATE TABLE users (
    id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    mobile VARCHAR(20) UNIQUE NOT NULL,
    nid VARCHAR(50) NOT NULL,
    password VARCHAR(100) NOT NULL
);

